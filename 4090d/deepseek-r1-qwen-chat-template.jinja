{# DeepSeek-R1-Distill-Qwen-14B Chat Template
   专为 llama.cpp 设计，适配 DeepSeek-R1 蒸馏模型的对话格式
   
   注意: DeepSeek-R1 系列模型官方建议不使用 system prompt
   所有指令应包含在 user prompt 中
#}

{%- set ns = namespace(system_content='') -%}

{# 收集 system prompt 内容（如果有的话），后续合并到第一个 user prompt -#}
{%- for message in messages -%}
{%- if message['role'] == 'system' -%}
{%- set ns.system_content = ns.system_content + message['content'] + '\n\n' -%}
{%- endif -%}
{%- endfor -%}

{# 输出对话历史 -#}
{%- set first_user = true -%}
{%- for message in messages -%}
{%- if message['role'] == 'user' -%}
{%- if first_user and ns.system_content -%}
{# 将 system prompt 合并到第一个 user prompt，符合官方建议 -#}
<｜User｜>{{ ns.system_content }}{{ message['content'] }}
{%- set first_user = false -%}
{%- else -%}
<｜User｜>{{ message['content'] }}
{%- endif -%}
{%- elif message['role'] == 'assistant' -%}
<｜Assistant｜>{{ message['content'] }}
{%- endif -%}
{%- endfor -%}

{# 生成 assistant 前缀 -#}
{%- if add_generation_prompt -%}
<｜Assistant｜>{%- endif -%}
