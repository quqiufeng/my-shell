{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "external_directory": "allow"
  },
  "compaction": {
    "auto": true,
    "tail_turns": 8
  },
  "model": "openai/qwen-q4-fix:latest",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Models",
      "options": {
        "baseURL": "http://localhost:11436/v1",
        "apiKey": "dummy",
        "timeout": 300000
      },
      "models": {
        "qwen2.5-coder-14b:latest": {
          "name": "Qwen2.5-Coder-14B Q4 (3080 20GB)",
          "maxContextWindow": 131072,
          "maxOutputTokens": 32768
        }
      }
    }
  }
}
